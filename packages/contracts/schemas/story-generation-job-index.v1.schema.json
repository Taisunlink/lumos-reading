{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.lumosreading.local/story-generation-job-index.v1.schema.json",
  "title": "StoryGenerationJobIndexV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_at",
    "jobs"
  ],
  "properties": {
    "schema_version": {
      "const": "story-generation-job-index.v1"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "jobs": {
      "type": "array",
      "items": {
        "$ref": "https://schemas.lumosreading.local/story-generation-job.v1.schema.json"
      }
    }
  }
}
