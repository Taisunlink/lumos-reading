{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.lumosreading.local/caregiver-dashboard.v1.schema.json",
  "title": "CaregiverDashboardV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "household_id",
    "household_name",
    "featured_package_id",
    "package_queue",
    "recent_events",
    "children",
    "weekly_plan",
    "progress_metrics",
    "generated_at"
  ],
  "properties": {
    "schema_version": {
      "const": "caregiver-dashboard.v1"
    },
    "household_id": {
      "$ref": "#/$defs/uuid"
    },
    "household_name": {
      "type": "string",
      "minLength": 1
    },
    "featured_package_id": {
      "$ref": "#/$defs/uuid"
    },
    "package_queue": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/storyPackage"
      }
    },
    "recent_events": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/readingEvent"
      }
    },
    "children": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/childSummary"
      }
    },
    "weekly_plan": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/weeklyPlanItem"
      }
    },
    "progress_metrics": {
      "$ref": "#/$defs/progressMetrics"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "uuid": {
      "type": "string",
      "format": "uuid"
    },
    "languageTag": {
      "type": "string",
      "pattern": "^[A-Za-z]{2,3}(-[A-Za-z0-9]{2,8})*$"
    },
    "url": {
      "type": "string",
      "format": "uri"
    },
    "storyPackageSafety": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "review_status"
      ],
      "properties": {
        "review_status": {
          "type": "string",
          "enum": [
            "approved",
            "limited_release",
            "recalled"
          ]
        },
        "reviewed_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "review_policy_version": {
          "type": "string"
        }
      }
    },
    "storyPackageTextRun": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "text",
        "lang"
      ],
      "properties": {
        "text": {
          "type": "string",
          "minLength": 1
        },
        "lang": {
          "$ref": "#/$defs/languageTag"
        },
        "tts_timing": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    },
    "storyPackageMedia": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "image_url": {
          "$ref": "#/$defs/url"
        },
        "audio_url": {
          "$ref": "#/$defs/url"
        },
        "thumbnail_url": {
          "$ref": "#/$defs/url"
        }
      }
    },
    "storyPackageOverlay": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "vocabulary": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "caregiver_prompt_ids": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "interaction_ids": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        }
      }
    },
    "storyPackagePage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "page_index",
        "text_runs"
      ],
      "properties": {
        "page_index": {
          "type": "integer",
          "minimum": 0
        },
        "text_runs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/storyPackageTextRun"
          }
        },
        "media": {
          "$ref": "#/$defs/storyPackageMedia"
        },
        "overlays": {
          "$ref": "#/$defs/storyPackageOverlay"
        }
      }
    },
    "storyPackage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "package_id",
        "story_master_id",
        "story_variant_id",
        "title",
        "language_mode",
        "difficulty_level",
        "age_band",
        "estimated_duration_sec",
        "release_channel",
        "safety",
        "pages"
      ],
      "properties": {
        "schema_version": {
          "const": "story-package.v1"
        },
        "package_id": {
          "$ref": "#/$defs/uuid"
        },
        "story_master_id": {
          "$ref": "#/$defs/uuid"
        },
        "story_variant_id": {
          "$ref": "#/$defs/uuid"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "subtitle": {
          "type": "string"
        },
        "language_mode": {
          "$ref": "#/$defs/languageTag"
        },
        "difficulty_level": {
          "type": "string",
          "minLength": 1
        },
        "age_band": {
          "type": "string",
          "minLength": 1
        },
        "estimated_duration_sec": {
          "type": "integer",
          "minimum": 0
        },
        "release_channel": {
          "type": "string",
          "enum": [
            "general",
            "pilot",
            "experimental",
            "internal"
          ]
        },
        "cover_image_url": {
          "$ref": "#/$defs/url"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "safety": {
          "$ref": "#/$defs/storyPackageSafety"
        },
        "pages": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/storyPackagePage"
          }
        }
      }
    },
    "readingEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "event_id",
        "event_type",
        "occurred_at",
        "session_id",
        "child_id",
        "package_id",
        "platform",
        "surface",
        "app_version",
        "payload"
      ],
      "properties": {
        "schema_version": {
          "const": "reading-event.v1"
        },
        "event_id": {
          "$ref": "#/$defs/uuid"
        },
        "event_type": {
          "type": "string",
          "enum": [
            "session_started",
            "session_completed",
            "page_viewed",
            "page_replayed_audio",
            "word_revealed_translation",
            "caregiver_prompt_opened",
            "caregiver_prompt_completed",
            "mode_changed",
            "assist_mode_enabled",
            "content_reported"
          ]
        },
        "occurred_at": {
          "type": "string",
          "format": "date-time"
        },
        "session_id": {
          "$ref": "#/$defs/uuid"
        },
        "child_id": {
          "$ref": "#/$defs/uuid"
        },
        "package_id": {
          "$ref": "#/$defs/uuid"
        },
        "page_index": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "platform": {
          "type": "string",
          "enum": [
            "ipadOS",
            "ios",
            "android",
            "web",
            "desktop-web",
            "unknown"
          ]
        },
        "surface": {
          "type": "string",
          "enum": [
            "child-app",
            "caregiver-web",
            "studio-web"
          ]
        },
        "app_version": {
          "type": "string",
          "minLength": 1
        },
        "language_mode": {
          "$ref": "#/$defs/languageTag"
        },
        "payload": {
          "type": "object"
        }
      }
    },
    "childSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "child_id",
        "name",
        "age_label",
        "focus",
        "weekly_goal",
        "current_package_id"
      ],
      "properties": {
        "child_id": {
          "$ref": "#/$defs/uuid"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "age_label": {
          "type": "string",
          "minLength": 1
        },
        "focus": {
          "type": "string",
          "minLength": 1
        },
        "weekly_goal": {
          "type": "string",
          "minLength": 1
        },
        "current_package_id": {
          "$ref": "#/$defs/uuid"
        }
      }
    },
    "weeklyPlanItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "day",
        "mode",
        "package_id",
        "objective"
      ],
      "properties": {
        "day": {
          "type": "string",
          "minLength": 1
        },
        "mode": {
          "type": "string",
          "minLength": 1
        },
        "package_id": {
          "$ref": "#/$defs/uuid"
        },
        "objective": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "progressMetrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "completed_sessions",
        "translation_reveals",
        "audio_replays"
      ],
      "properties": {
        "completed_sessions": {
          "type": "integer",
          "minimum": 0
        },
        "translation_reveals": {
          "type": "integer",
          "minimum": 0
        },
        "audio_replays": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}
