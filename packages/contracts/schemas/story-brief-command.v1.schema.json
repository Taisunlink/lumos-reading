{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.lumosreading.local/story-brief-command.v1.schema.json",
  "title": "StoryBriefCommandV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "title",
    "theme",
    "premise",
    "language_mode",
    "age_band",
    "desired_page_count",
    "requested_by",
    "requested_at"
  ],
  "properties": {
    "schema_version": {
      "const": "story-brief-command.v1"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "theme": {
      "type": "string",
      "minLength": 1
    },
    "premise": {
      "type": "string",
      "minLength": 1
    },
    "language_mode": {
      "type": "string",
      "minLength": 1
    },
    "age_band": {
      "type": "string",
      "minLength": 1
    },
    "desired_page_count": {
      "type": "integer",
      "minimum": 1,
      "maximum": 10
    },
    "source_outline": {
      "type": [
        "string",
        "null"
      ]
    },
    "requested_by": {
      "type": "string",
      "minLength": 1
    },
    "requested_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
