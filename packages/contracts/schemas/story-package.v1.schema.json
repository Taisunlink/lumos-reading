{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.lumosreading.local/story-package.v1.schema.json",
  "title": "StoryPackageManifestV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "package_id",
    "story_master_id",
    "story_variant_id",
    "title",
    "language_mode",
    "difficulty_level",
    "age_band",
    "estimated_duration_sec",
    "release_channel",
    "safety",
    "pages"
  ],
  "properties": {
    "schema_version": {
      "const": "story-package.v1"
    },
    "package_id": {
      "$ref": "#/$defs/uuid"
    },
    "story_master_id": {
      "$ref": "#/$defs/uuid"
    },
    "story_variant_id": {
      "$ref": "#/$defs/uuid"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "subtitle": {
      "type": "string"
    },
    "language_mode": {
      "$ref": "#/$defs/languageTag"
    },
    "difficulty_level": {
      "type": "string",
      "minLength": 1
    },
    "age_band": {
      "type": "string",
      "minLength": 1
    },
    "estimated_duration_sec": {
      "type": "integer",
      "minimum": 0
    },
    "release_channel": {
      "type": "string",
      "enum": [
        "general",
        "pilot",
        "experimental",
        "internal"
      ]
    },
    "cover_image_url": {
      "$ref": "#/$defs/url"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "safety": {
      "$ref": "#/$defs/safety"
    },
    "pages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/page"
      }
    }
  },
  "$defs": {
    "uuid": {
      "type": "string",
      "format": "uuid"
    },
    "languageTag": {
      "type": "string",
      "pattern": "^[A-Za-z]{2,3}(-[A-Za-z0-9]{2,8})*$"
    },
    "url": {
      "type": "string",
      "format": "uri"
    },
    "safety": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "review_status"
      ],
      "properties": {
        "review_status": {
          "type": "string",
          "enum": [
            "approved",
            "limited_release",
            "recalled"
          ]
        },
        "reviewed_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "review_policy_version": {
          "type": "string"
        }
      }
    },
    "textRun": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "text",
        "lang"
      ],
      "properties": {
        "text": {
          "type": "string",
          "minLength": 1
        },
        "lang": {
          "$ref": "#/$defs/languageTag"
        },
        "tts_timing": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    },
    "media": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "image_url": {
          "$ref": "#/$defs/url"
        },
        "audio_url": {
          "$ref": "#/$defs/url"
        },
        "thumbnail_url": {
          "$ref": "#/$defs/url"
        }
      }
    },
    "overlay": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "vocabulary": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "caregiver_prompt_ids": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "interaction_ids": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        }
      }
    },
    "page": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "page_index",
        "text_runs"
      ],
      "properties": {
        "page_index": {
          "type": "integer",
          "minimum": 0
        },
        "text_runs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/textRun"
          }
        },
        "media": {
          "$ref": "#/$defs/media"
        },
        "overlays": {
          "$ref": "#/$defs/overlay"
        }
      }
    }
  }
}
