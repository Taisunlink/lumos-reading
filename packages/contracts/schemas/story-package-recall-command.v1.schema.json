{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.lumosreading.local/story-package-recall-command.v1.schema.json",
  "title": "StoryPackageRecallCommandV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "release_id",
    "requested_by",
    "requested_at"
  ],
  "properties": {
    "schema_version": {
      "const": "story-package-recall-command.v1"
    },
    "release_id": {
      "$ref": "https://schemas.lumosreading.local/story-package.v1.schema.json#/$defs/uuid"
    },
    "requested_by": {
      "type": "string",
      "minLength": 1
    },
    "requested_at": {
      "type": "string",
      "format": "date-time"
    },
    "reason": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
