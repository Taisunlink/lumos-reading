{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.lumosreading.local/story-package-draft-index.v1.schema.json",
  "title": "StoryPackageDraftIndexV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_at",
    "drafts"
  ],
  "properties": {
    "schema_version": {
      "const": "story-package-draft-index.v1"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "drafts": {
      "type": "array",
      "items": {
        "$ref": "https://schemas.lumosreading.local/story-package-draft.v1.schema.json"
      }
    }
  }
}
