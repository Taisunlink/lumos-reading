{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.lumosreading.local/reading-session-create.v2.schema.json",
  "title": "ReadingSessionCreateV2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "child_id",
    "package_id",
    "started_at",
    "mode",
    "language_mode",
    "assist_mode"
  ],
  "properties": {
    "child_id": {
      "$ref": "#/$defs/uuid"
    },
    "package_id": {
      "$ref": "#/$defs/uuid"
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "mode": {
      "type": "string",
      "minLength": 1
    },
    "language_mode": {
      "$ref": "#/$defs/languageTag"
    },
    "assist_mode": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "$defs": {
    "uuid": {
      "type": "string",
      "format": "uuid"
    },
    "languageTag": {
      "type": "string",
      "pattern": "^[A-Za-z]{2,3}(-[A-Za-z0-9]{2,8})*$"
    }
  }
}
