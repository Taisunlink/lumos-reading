{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.lumosreading.local/story-package-build-command.v1.schema.json",
  "title": "StoryPackageBuildCommandV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "build_reason",
    "requested_by",
    "requested_at"
  ],
  "properties": {
    "schema_version": {
      "const": "story-package-build-command.v1"
    },
    "build_reason": {
      "type": "string",
      "minLength": 1
    },
    "requested_by": {
      "type": "string",
      "minLength": 1
    },
    "requested_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
