{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.lumosreading.local/caregiver-progress.v1.schema.json",
  "title": "CaregiverProgressV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "household_id",
    "recent_events",
    "progress_metrics",
    "generated_at"
  ],
  "properties": {
    "schema_version": {
      "const": "caregiver-progress.v1"
    },
    "household_id": {
      "$ref": "#/$defs/uuid"
    },
    "recent_events": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/progressEvent"
      }
    },
    "progress_metrics": {
      "$ref": "#/$defs/progressMetrics"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "uuid": {
      "type": "string",
      "format": "uuid"
    },
    "languageTag": {
      "type": "string",
      "pattern": "^[A-Za-z]{2,3}(-[A-Za-z0-9]{2,8})*$"
    },
    "readingEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "event_id",
        "event_type",
        "occurred_at",
        "session_id",
        "child_id",
        "package_id",
        "platform",
        "surface",
        "app_version",
        "payload"
      ],
      "properties": {
        "schema_version": {
          "const": "reading-event.v1"
        },
        "event_id": {
          "$ref": "#/$defs/uuid"
        },
        "event_type": {
          "type": "string",
          "enum": [
            "session_started",
            "session_completed",
            "page_viewed",
            "page_replayed_audio",
            "word_revealed_translation",
            "caregiver_prompt_opened",
            "caregiver_prompt_completed",
            "mode_changed",
            "assist_mode_enabled",
            "content_reported"
          ]
        },
        "occurred_at": {
          "type": "string",
          "format": "date-time"
        },
        "session_id": {
          "$ref": "#/$defs/uuid"
        },
        "child_id": {
          "$ref": "#/$defs/uuid"
        },
        "package_id": {
          "$ref": "#/$defs/uuid"
        },
        "page_index": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "platform": {
          "type": "string",
          "enum": [
            "ipadOS",
            "ios",
            "android",
            "web",
            "desktop-web",
            "unknown"
          ]
        },
        "surface": {
          "type": "string",
          "enum": [
            "child-app",
            "caregiver-web",
            "studio-web"
          ]
        },
        "app_version": {
          "type": "string",
          "minLength": 1
        },
        "language_mode": {
          "$ref": "#/$defs/languageTag"
        },
        "payload": {
          "type": "object"
        }
      }
    },
    "progressEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "event",
        "child_name",
        "package_title"
      ],
      "properties": {
        "event": {
          "$ref": "#/$defs/readingEvent"
        },
        "child_name": {
          "type": "string",
          "minLength": 1
        },
        "package_title": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "progressMetrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "completed_sessions",
        "translation_reveals",
        "audio_replays"
      ],
      "properties": {
        "completed_sessions": {
          "type": "integer",
          "minimum": 0
        },
        "translation_reveals": {
          "type": "integer",
          "minimum": 0
        },
        "audio_replays": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}
