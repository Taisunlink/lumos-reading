{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.lumosreading.local/story-generation-job.v1.schema.json",
  "title": "StoryGenerationJobV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "job_id",
    "brief_id",
    "package_id",
    "job_type",
    "status",
    "attempts",
    "requested_by",
    "requested_at"
  ],
  "properties": {
    "schema_version": {
      "const": "story-generation-job.v1"
    },
    "job_id": {
      "type": "string",
      "format": "uuid"
    },
    "brief_id": {
      "type": "string",
      "format": "uuid"
    },
    "package_id": {
      "type": "string",
      "format": "uuid"
    },
    "job_type": {
      "type": "string",
      "enum": [
        "brief_to_draft",
        "draft_to_media"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "queued",
        "running",
        "succeeded",
        "failed"
      ]
    },
    "selected_provider": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "qwen",
        "vertex",
        "openai",
        "placeholder",
        null
      ]
    },
    "attempts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/provider_attempt"
      }
    },
    "generated_asset_keys": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "requested_by": {
      "type": "string",
      "minLength": 1
    },
    "requested_at": {
      "type": "string",
      "format": "date-time"
    },
    "completed_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "failure_reason": {
      "type": [
        "string",
        "null"
      ]
    },
    "notes": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "$defs": {
    "provider_attempt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider",
        "status"
      ],
      "properties": {
        "provider": {
          "type": "string",
          "enum": [
            "qwen",
            "vertex",
            "openai",
            "placeholder"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "succeeded",
            "failed",
            "skipped"
          ]
        },
        "reason": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    }
  }
}
